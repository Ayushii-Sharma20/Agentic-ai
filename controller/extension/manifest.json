{
  "manifest_version": 3,
  "name": "AI Terms Analyzer",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}